{
  "expo": {
    "name": "Qup Pulse",
    "slug": "qup-pulse",
    "version": "1.1",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "userInterfaceStyle": "automatic",
    "scheme": "quppulse",
    "splash": {
      "image": "./assets/images/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#0e1116"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.qup.pulse",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Allow photo access to send pictures in chat.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.qup.pulse",
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo.png",
        "backgroundColor": "#0e1116"
      },
      "permissions": [
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow photo access to send pictures in chat."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "508f09c4-d482-43d9-92c7-7605aa41dc5a"
      }
    },
    "owner": "janstovr"
  }
}
